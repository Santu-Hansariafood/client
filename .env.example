# Public site URL for canonical links and OG tags (no trailing slash)
VITE_SITE_URL=https://bid.hansariafood.in

# API (optional; defaults to /api with proxy in dev)
# VITE_API_BASE_URL=/api
# VITE_API_KEY=

# Server Configuration
# NODE_ENV=production
# PORT=5000
# CORS_ORIGIN=https://bid.hansariafood.in

# MongoDB Configuration
# MONGODB_URI=mongodb://localhost:27017/hansaria
# MONGODB_MAX_POOL=20
# MONGODB_MIN_POOL=2
# MONGODB_MAX_IDLE_MS=30000
# MONGODB_SOCKET_TIMEOUT_MS=20000
# MONGODB_READ_PREFERENCE=primary
# MONGODB_COMPRESSORS=zlib

# Security
# API_KEY=your_secure_api_key_here
# JWT_SECRET=your_secure_jwt_secret_here

# Cluster Mode (enabled by default in production, set to 0 to disable)
# CLUSTER_MODE=1

# Email Configuration
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-email-password
